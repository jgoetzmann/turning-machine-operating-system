FROM ubuntu:24.04

ARG DEBIAN_FRONTEND=noninteractive

# Base build/runtime deps (kernel + qemu tests + python tooling)
RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates curl git make file \
    python3 python3-venv python3-pip \
    build-essential \
    nasm \
    qemu-system-x86 \
    clang lld \
  && rm -rf /var/lib/apt/lists/*

# Rust nightly + rust-src + i686 bare-metal target
ENV RUSTUP_HOME=/opt/rustup \
    CARGO_HOME=/opt/cargo \
    PATH=/opt/cargo/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal --default-toolchain nightly \
  && rustup component add rust-src --toolchain nightly \
  && rustup target add i686-unknown-none --toolchain nightly

WORKDIR /work

